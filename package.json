{
    "name": "ramda-doc",
    "version": "1.0.0",
    "private": true,
    "workspaces": ["vendor/*"],
    "scripts": {
        "serve": "properdocs serve --open",
        "build": "properdocs build",
        "publish": "properdocs gh-deploy",
        "setup": "./scripts/setup.nu",
        "setup:all": "./scripts/setup.nu --fetch-d2 true",
        "setup:d2": "./scripts/setup.nu fetch-d2",
        "postinstall": "rm -rf node_modules && bun setup || true"
    }
}
